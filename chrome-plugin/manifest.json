{
  "manifest_version": 3,
  "name": "大屏AI智能助手",
  "version": "1.0.0",
  "description": "基于microfox的可视化大屏讲解助手",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["<all_urls>"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "css": ["style.css"],
      "js": ["content.js"]
    }
  ],
  "action": {
    "default_title": "开启大屏助手"
  }
}